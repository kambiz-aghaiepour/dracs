# Required: Dell TechDirect API credentials
CLIENT_ID=<YOUR DELL API CLIENT ID HERE>
CLIENT_SECRET=<YOUR DELL API CLIENT SECRET HERE>
TOKEN_URL=https://apigtwb2c.us.dell.com/auth/oauth/v2/token

# Required: iDRAC DNS configuration
# DRACS_DNS_STRING: String to add to hostname for iDRAC FQDN
# DRACS_DNS_MODE: How to add the string ('prefix' or 'suffix')
#
# Examples:
# Prefix mode: "mgmt-" + "host01.example.com" = "mgmt-host01.example.com"
DRACS_DNS_STRING=mgmt-
DRACS_DNS_MODE=prefix
#
# Suffix mode: "host01" + "-mm" + ".example.com" = "host01-mm.example.com"
# DRACS_DNS_STRING=-mm
# DRACS_DNS_MODE=suffix

# Optional: SNMP community string (defaults to 'public')
SNMP_COMMUNITY=public

# Optional: Enable debug logging via environment (can also use -d flag)
DEBUG=false

# Flask secret key for session cookie signing
# IMPORTANT: For production, generate a secure key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Replace the default value below with the generated key.
FLASK_SECRET_KEY=dev-secret-key-change-in-production-12345678901234567890123456789012

# Web interface admin credentials
# Change these from the defaults for production use
WEBADMIN_USER=admin
WEBADMIN_PASSWORD=admin

# Optional: Database path (defaults to ./warranty.db)
DRACS_DB=./warranty.db

# Optional: Auto-refresh frequency in seconds (0 to disable, defaults to 10)
REFRESH_FREQUENCY=10

# Optional: Highlight expired warranties in red (defaults to true)
HIGHLIGHT_EXPIRED=true

# Optional: Highlight systems expiring within this many days in yellow (defaults to 30)
HIGHLIGHT_EXPIRING=30

# Optional: Default number of systems per page (defaults to 20)
DEFAULT_PAGE_SIZE=20

# Optional: Highlight firmware versions based on how outdated they are (defaults to true)
HIGHLIGHT_FIRMWARE=true

# Optional: Highlight BIOS versions based on how outdated they are (defaults to true)
HIGHLIGHT_BIOS=true

# Required: anonymous FTP server where firmware images are stored
# See README.md on setting up files on your FTP server for iDRAC firmware images.
DRACS_FTP_SERVER=<IP ADDRESS TO YOUR ANONYMOUS FTP SERVER>

# Required: anonymous NFS server where firmware images are stored
# See README.md on setting up NFS server for BIOS images.
DRACS_NFS_SERVER=<IP ADDRESS TO YOUR NFS SERVER>
DRACS_NFS_PATH=/path/to/bios/images

# Optional: Gunicorn bind address (defaults to 127.0.0.1:1888)
# Change to 0.0.0.0:1888 to listen on all interfaces
# DRACS_BIND=127.0.0.1:1888

