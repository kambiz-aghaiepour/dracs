# Required: Dell TechDirect API credentials
CLIENT_ID=<YOUR DELL API CLIENT ID HERE>
CLIENT_SECRET=<YOUR DELL API CLIENT SECRET HERE>
TOKEN_URL=https://apigtwb2c.us.dell.com/auth/oauth/v2/token

# Required: iDRAC DNS configuration
# DRACS_DNS_STRING: String to add to hostname for iDRAC FQDN
# DRACS_DNS_MODE: How to add the string ('prefix' or 'suffix')
#
# Examples:
# Prefix mode: "mgmt-" + "host01.example.com" = "mgmt-host01.example.com"
DRACS_DNS_STRING=mgmt-
DRACS_DNS_MODE=prefix
#
# Suffix mode: "host01" + "-mm" + ".example.com" = "host01-mm.example.com"
# DRACS_DNS_STRING=-mm
# DRACS_DNS_MODE=suffix

# Optional: SNMP community string (defaults to 'public')
SNMP_COMMUNITY=public

# Optional: Enable debug logging via environment (can also use -d flag)
DEBUG=false

# Flask secret key for session cookie signing
# IMPORTANT: For production, generate a secure key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Replace the default value below with the generated key.
FLASK_SECRET_KEY=dev-secret-key-change-in-production-12345678901234567890123456789012

# Web interface admin credentials
# Change these from the defaults for production use
WEBADMIN_USER=admin
WEBADMIN_PASSWORD=admin

# Optional: Database path (defaults to ./warranty.db)
DRACS_DB=./warranty.db

# Optional: Auto-refresh frequency in seconds (0 to disable, defaults to 10)
REFRESH_FREQUENCY=10

# Optional: Highlight expired warranties in red (defaults to true)
HIGHLIGHT_EXPIRED=true

# Optional: Highlight systems expiring within this many days in yellow (defaults to 30)
HIGHLIGHT_EXPIRING=30

# Optional: Default number of systems per page (defaults to 20)
DEFAULT_PAGE_SIZE=20

# Optional: Highlight firmware versions based on how outdated they are (defaults to true)
HIGHLIGHT_FIRMWARE=true

# Optional: Highlight BIOS versions based on how outdated they are (defaults to true)
HIGHLIGHT_BIOS=true

# Firmware and BIOS images are served via HTTP from /var/lib/dracs/web/
# Place firmware .d9 files in /var/lib/dracs/web/firmware/
# Place BIOS .EXE files in /var/lib/dracs/web/bios/
# See README.md for image naming conventions and setup details.

# Optional: Override the server and URI used to serve firmware/BIOS images to iDRACs.
# Defaults to http://<FQDN>/firmware/ and http://<FQDN>/bios/ where FQDN is the
# hostname of the DRACS server.
# DRACS_FIRMWARE_SERVER=firmware.example.com
# DRACS_FIRMWARE_URI=/firmware/
# DRACS_BIOS_SERVER=bios.example.com
# DRACS_BIOS_URI=/bios/

# Optional: Gunicorn bind address (defaults to 127.0.0.1:1888)
# Change to 0.0.0.0:1888 to listen on all interfaces
# DRACS_BIND=127.0.0.1:1888

# Optional: Directory for firmware/BIOS update logs (defaults to logs/)
# RPM installs set this to /var/log/dracs via the systemd service
# DRACS_LOG_DIR=logs

# Optional: API token expiry in seconds (default: 36000 = 10 hours)
# Tokens expire after this many seconds of inactivity
# DRACS_TOKEN_EXPIRY=36000

# VNC Console: Enable browser-based VNC console access to iDRAC interfaces
# Requires websockify and a properly configured nginx reverse proxy
# VNC_ENABLE=false
# VNC_TIMEOUT=30
# VNC_MAX_SESSIONS=20
# VNC_WEBSOCKIFY_PORT=6080
# VNC_CONSOLE_SIZE=800x600
# VNC_PROXY_ENABLE: Start an x11vnc -reflect repeater proxy per session so that
# multiple dracs users can share one read-write iDRAC VNC connection.
# Requires x11vnc to be installed (dnf install x11vnc / apt install x11vnc).
# VNC_PROXY_ENABLE=false

# IPMI Serial over LAN (SOL): Enable browser-based SOL console access via conserver
# Requires conserver and ipmitool to be installed
# SOL_ENABLE=false
# SOL_CONSERVER_CF=/etc/dracs/conserver.cf
# SOL_CONSERVER_PASSWD=/etc/dracs/conserver.passwd
# SOL_CONSERVER_LOGDIR=/var/log/dracs/conserver
# SOL_CONSERVER_PORT=3109
# SOL_CONSERVER_SLAVE_PORT=3110
# Optional: encrypt conserver authentication using the same TLS cert as nginx.
# DRACS automatically uses /etc/pki/tls/certs/<hostname>.{pem,key} if those
# files exist — the same paths used by dracs_ssl.conf.example — so no
# configuration is needed on a standard DRACS deployment.
# Set these explicitly only if your cert/key are in non-standard locations.
# SOL_SSL_CERT=/etc/pki/tls/certs/dracs.example.com.pem
# SOL_SSL_KEY=/etc/pki/tls/certs/dracs.example.com.key
# Optional: CA cert for self-signed / private-CA certificates.
# Required only if the cert is NOT already trusted by the system CA bundle.
# For a standard DRACS deployment, leave this unset.
# SOL_SSL_CA=/etc/pki/ca-trust/source/anchors/my-ca.pem

# Google OAuth2 (SSO) — optional; defaults to disabled
# Set GOOGLE_AUTH=true to enable SSO login for all non-superadmin users.
# Requires a Google Cloud OAuth2 client secret JSON file.
# See README.md for setup instructions.
# GOOGLE_AUTH=false
# GOOGLE_CLIENT_SECRET_PATH=/etc/dracs/google_client_secret.json

