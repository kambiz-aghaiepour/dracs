# DRACS Job Scheduler Configuration
#
# Each section defines a scheduled task. Section names must be unique.
#
# Fields:
#   type     = tsr | refresh | clear_job_queue
#   schedule = daily | weekly
#   time     = HH:MM (24-hour format)
#   day      = monday | tuesday | ... | sunday (required for weekly)
#   target   = all | model:<model> | <hostname>
#   site     = <site_name> (optional, defaults to all sites if not specified)
#   keep_max = <integer>   (optional, tsr only) max TSRs to retain per host;
#                          before each collection the oldest TSRs are pruned so
#                          that after collection exactly keep_max remain
#
# Examples:
#
# [tsr-weekly]
# type = tsr
# schedule = weekly
# day = sunday
# time = 02:00
# target = all
# keep_max = 2
#
# [refresh-daily]
# type = refresh
# schedule = daily
# time = 04:00
# target = all
#
# [tsr-r660-daily]
# type = tsr
# schedule = daily
# time = 03:00
# target = model:R660
#
# [clear-idrac-weekly]
# type = clear_job_queue
# schedule = weekly
# day = saturday
# time = 01:00
# target = all
